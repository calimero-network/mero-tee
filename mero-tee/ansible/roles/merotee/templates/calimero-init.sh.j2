#!/bin/bash
# Calimero locked-down image init (R6). Uses baked merod/meroctl/mero-auth if present;
# otherwise downloads from GitHub (legacy, requires merod-version metadata).
set -euo pipefail

LOG="/var/log/calimero-init.log"
BIN_DIR="/usr/local/bin"
CALIMERO_HOME="/mnt/data/calimero"
CALIMERO_NODE="default"
IMAGE_PROFILE="{{ lockdown_profile }}"
IMAGE_ROLE="node"
MEROD_MODE="{{ merod_mode }}"
METADATA_URL="http://metadata.google.internal/computeMetadata/v1/instance/attributes"
METADATA_HEADER="Metadata-Flavor: Google"

# Whitelisted keys only (no arbitrary script execution)
get_meta() {
  local key="$1"
  curl -sf -H "$METADATA_HEADER" "${METADATA_URL}/${key}" 2>/dev/null || true
}

log() { echo "[$(date -Iseconds)] $*" | tee -a "$LOG"; }

log "Starting Calimero init (profile=$IMAGE_PROFILE mode=$MEROD_MODE)"

# --- Extend RTMR3 (user-defined) for attestation; different per image, cannot be faked ---
# RTMR3 is empty by default; extending with role+profile+root_hash makes each image unique.
# Keep this best-effort at boot so merod can still start if kernel/sysfs support is unavailable.
# Newer kernels (e.g. 6.17+ GCP) expose RTMR under tdx_guest/measurements/; older use tdx_guest/mr/.
ROOT_HASH=$(grep -oE 'calimero\.root_hash=[^ ]+' /proc/cmdline 2>/dev/null | cut -d= -f2 || echo "none")
RTMR3_EXTEND_FILE="$(mktemp)"
if printf 'calimero-rtmr3-v2:%s:%s:%s' "$IMAGE_ROLE" "$IMAGE_PROFILE" "${ROOT_HASH}" | openssl dgst -sha384 -binary > "$RTMR3_EXTEND_FILE" 2>/dev/null; then
  # shellcheck disable=SC2002
  RTMR3_EXTEND_SIZE="$(cat "$RTMR3_EXTEND_FILE" | wc -c | tr -d '[:space:]')"
  if [[ "${RTMR3_EXTEND_SIZE}" == "48" ]]; then
    modprobe tdx_guest 2>/dev/null || true
    RTMR3_SYSFS=""
    for candidate in \
      "/sys/class/misc/tdx_guest/measurements/rtmr3:sha384" \
      "/sys/class/misc/tdx_guest/mr/rtmr3:sha384"; do
      if [[ -e "${candidate}" ]] && [[ -w "${candidate}" ]]; then
        RTMR3_SYSFS="${candidate}"
        break
      fi
    done
    if [[ -n "${RTMR3_SYSFS}" ]]; then
      if cat "$RTMR3_EXTEND_FILE" > "${RTMR3_SYSFS}" 2>/dev/null; then
        log "Extended RTMR3 for attestation (role=$IMAGE_ROLE profile=$IMAGE_PROFILE root_hash=${ROOT_HASH:0:16}... via ${RTMR3_SYSFS})"
      else
        log "WARN: RTMR3 extend write failed (${RTMR3_SYSFS})"
      fi
    else
      log "RTMR3 extend skipped (no writable rtmr3:sha384 under /sys/class/misc/tdx_guest/measurements/ or .../mr/)"
    fi
  else
    log "WARN: RTMR3 extend input has unexpected size (${RTMR3_EXTEND_SIZE}, expected 48)"
  fi
else
  log "WARN: Failed to generate RTMR3 extend input digest"
fi
rm -f "$RTMR3_EXTEND_FILE"

# --- R7: observability off by default; enable only if endpoint set ---
systemctl stop vmagent vector 2>/dev/null || true
systemctl disable vmagent vector 2>/dev/null || true

# Optional with defaults
SERVER_PORT=$(get_meta "server-port")
SERVER_PORT=${SERVER_PORT:-2428}
SWARM_PORT=$(get_meta "swarm-port")
SWARM_PORT=${SWARM_PORT:-2528}
TEE_RELEASE_VERSION=$(get_meta "tee-release-version")
METRICS_ENDPOINT=$(get_meta "metrics-endpoint")
METRICS_SECRET=$(get_meta "metrics-secret-name")
LOGS_ENDPOINT=$(get_meta "logs-endpoint")
LOGS_SECRET=$(get_meta "logs-secret-name")

# Use baked binaries if present (image built with calimero-core); else download at runtime
if [[ -x "${BIN_DIR}/merod" ]] && [[ -x "${BIN_DIR}/meroctl" ]] && [[ -x "${BIN_DIR}/mero-auth" ]]; then
  log "Using baked merod/meroctl/mero-auth from image"
else
  MEROD_VERSION=$(get_meta "merod-version")
  if [[ -z "${MEROD_VERSION:-}" ]]; then
    log "ERROR: merod-version metadata required (binaries not baked in image)"
    exit 1
  fi
  CPU_PLATFORM=$(uname -m)
  BASE_URL="https://github.com/calimero-network/core/releases/download/${MEROD_VERSION}"
  log "merod-version=$MEROD_VERSION server-port=$SERVER_PORT swarm-port=$SWARM_PORT"
  download() {
    local name="$1"
    local tar="${name}_${CPU_PLATFORM}-unknown-linux-gnu.tar.gz"
    log "Downloading $name from $BASE_URL ..."
    wget -q -O "/tmp/${name}.tar.gz" "${BASE_URL}/${tar}"
    tar -xzf "/tmp/${name}.tar.gz" -C "$BIN_DIR"
    chmod 0755 "$BIN_DIR/$name"
    rm -f "/tmp/${name}.tar.gz"
  }
  download merod
  download meroctl
  download mero-auth
fi

log "server-port=$SERVER_PORT swarm-port=$SWARM_PORT"

if [[ -n "${TEE_RELEASE_VERSION:-}" ]]; then
  # Prevent EnvironmentFile injection: strip line breaks and quote/escape value.
  SANITIZED_TEE_RELEASE_VERSION=${TEE_RELEASE_VERSION//$'\n'/}
  SANITIZED_TEE_RELEASE_VERSION=${SANITIZED_TEE_RELEASE_VERSION//$'\r'/}
  ESCAPED_TEE_RELEASE_VERSION=${SANITIZED_TEE_RELEASE_VERSION//\\/\\\\}
  ESCAPED_TEE_RELEASE_VERSION=${ESCAPED_TEE_RELEASE_VERSION//\"/\\\"}
  printf 'MERO_TEE_VERSION="%s"\n' "$ESCAPED_TEE_RELEASE_VERSION" > /etc/calimero/merod.env
  chmod 0644 /etc/calimero/merod.env
  log "Configured MERO_TEE_VERSION from tee-release-version metadata"
else
  rm -f /etc/calimero/merod.env
fi

init_node() {
  if [[ "$MEROD_MODE" == "read-only" ]]; then
    "$BIN_DIR/merod" --home "$CALIMERO_HOME" --node "$CALIMERO_NODE" init \
      --mode read-only \
      --advertise-address \
      --server-port "$SERVER_PORT" \
      --swarm-port "$SWARM_PORT"
  else
    "$BIN_DIR/merod" --home "$CALIMERO_HOME" --node "$CALIMERO_NODE" init \
      --advertise-address \
      --server-port "$SERVER_PORT" \
      --swarm-port "$SWARM_PORT"
  fi
}

mkdir -p "$CALIMERO_HOME"
if [[ ! -d "$CALIMERO_HOME/$CALIMERO_NODE" ]]; then
  log "Initializing Calimero node..."
  init_node
else
  log "Calimero node already initialized at $CALIMERO_HOME/$CALIMERO_NODE; skipping init"
fi

if [[ "$MEROD_MODE" == "read-only" ]]; then
  log "Applying read-only merod config (jsonrpc/sse/websocket disabled)..."
  "$BIN_DIR/merod" --home "$CALIMERO_HOME" --node "$CALIMERO_NODE" config \
    'server.jsonrpc.enabled=false' \
    'server.sse.enabled=false' \
    'server.websocket.enabled=false' \
    || log "WARN: failed to apply read-only merod config"
fi

log "Starting services..."
systemctl daemon-reload
systemctl enable merod mero-auth traefik
# Start non-blocking to avoid deadlock with units that declare After=calimero-init.service.
systemctl start --no-block merod mero-auth traefik
log "Queued non-blocking start for merod, mero-auth, and traefik"

# R7: start vmagent only if metrics-endpoint set
if [[ -n "${METRICS_ENDPOINT:-}" ]]; then
  AUTH="false"
  SECRET_NAME=""
  [[ -n "${METRICS_SECRET:-}" ]] && AUTH="true" && SECRET_NAME="$METRICS_SECRET"
  if [[ -f /etc/vmagent/configure_vmagent.sh ]] && [[ -f /etc/vmagent/scrape_config.yml ]]; then
    /etc/vmagent/configure_vmagent.sh /etc/vmagent/scrape_config.yml "$METRICS_ENDPOINT" "$AUTH" gcp "$SECRET_NAME" || log "WARN: vmagent configure failed"
  else
    log "WARN: vmagent config or script missing, skipping"
  fi
fi

# R7: start vector only if logs-endpoint set
if [[ -n "${LOGS_ENDPOINT:-}" ]]; then
  AUTH="false"
  SECRET_NAME=""
  [[ -n "${LOGS_SECRET:-}" ]] && AUTH="true" && SECRET_NAME="$LOGS_SECRET"
  if [[ -f /etc/vector/configure_vector.sh ]] && [[ -f /etc/vector/vector_partial.yaml ]]; then
    /etc/vector/configure_vector.sh /etc/vector/vector_partial.yaml "$LOGS_ENDPOINT" "$AUTH" gcp "$SECRET_NAME" || log "WARN: vector configure failed"
  else
    log "WARN: vector config or partial missing, skipping"
  fi
fi

log "Calimero init completed"
